---
// 出典描画。親行に紐づく出典行を1行ずつ
//   「descriptor（url があればリンク、referenced_at があれば日付併記）」で描画する。
// label 文字列は描画しない。editor_verified の行は「編纂者確認（日付）」のみ描画する。
// 出典が無ければ何も描画しない（video_songs など出典子テーブルを持たない関係を含む）。
import type { SourceEntry } from '../lib/entities.ts';

interface Props {
  sources: SourceEntry[];
  summary: string; // details の見出し（出典 / Sources）
  verifiedLabel: string; // editor_verified の表示語（編纂者確認 / Editor-verified）
}
const { sources, summary, verifiedLabel } = Astro.props as Props;
---
{sources.length > 0 && (
  <details class="srcbox">
    <summary>{summary}</summary>
    {sources.map((s) => (
      <div class="src">
        {s.label === 'editor_verified' ? (
          <>{verifiedLabel}{s.referencedAt && `（${s.referencedAt}）`}</>
        ) : (
          <>
            {s.url ? <a href={s.url}>{s.descriptor}</a> : s.descriptor}
            {s.referencedAt && `（${s.referencedAt}）`}
          </>
        )}
      </div>
    ))}
  </details>
)}
