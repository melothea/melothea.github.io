---
// 出典描画。親行に紐づく出典（sources.id 昇順）を1行ずつ描画する：
//   labelの表示語 +（url があればURL原文リンク／catalog_no があれば逐語併記）
//   +（referenced_at があれば日付併記）。
// editor_verified の行は label の表示語＋日付のみ（record_ref は描画しない。url・catalog_no は
// DB制約によりeditor_verified行では常にNULL）。
// 出典が無ければ何も描画しない（video_songs など出典子テーブルを持たない関係を含む）。
import type { SourceEntry } from '../lib/entities.ts';

interface Props {
  sources: SourceEntry[];
  summary: string; // details の見出し（出典 / Sources）
  labelText: Record<string, string>; // label値 → 表示語（sourceLabel[lang]）
}
const { sources, summary, labelText } = Astro.props as Props;
---
{sources.length > 0 && (
  <details class="srcbox">
    <summary>{summary}</summary>
    {sources.map((s) => (
      <div class="src">
        {labelText[s.label] ?? s.label}
        {s.url && <> <a href={s.url}>{s.url}</a></>}
        {s.catalogNo && ` ${s.catalogNo}`}
        {s.referencedAt && `（${s.referencedAt}）`}
      </div>
    ))}
  </details>
)}
