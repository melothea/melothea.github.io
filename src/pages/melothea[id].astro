---
// 言語中立ハブ（実体URI＝/melothea{n}/）。言語を特権化せず、閲覧言語に依らず真である事実を載せる
// 実態ページ：ID・種別・年・種別区分と、クレジットグラフ（役割語彙キー＋逐語名＋出典）。そこから
// ja/en の各言語ページへ導く。hreflang の x-default 受け皿を兼ねる。
import Base from '../layouts/Base.astro';
import SourceList from '../components/SourceList.astro';
import { allEntities, getVideo, neutralName, songYear, videoYear,
  songArtists, songCredits, videosOfSong, videoSongs, videoCredits, videoSongCreditGroups,
  videoCreditsOfEntity, songCreditsOfEntity, songArtistOf, entityTypeOf,
  sourcesFor, type SourceEntry } from '../lib/entities.ts';
import { bi, neutralPath, langPath, neutralHome, typeLabel, SITE_NAME } from '../lib/i18n.ts';
import type { EntityRow } from '../lib/db.ts';

export function getStaticPaths() {
  // status で絞らず draft 行もページ生成する。
  return allEntities().map((e) => ({ params: { id: String(e.id) }, props: { entity: e } }));
}
const { entity } = Astro.props as { entity: EntityRow };
const id = entity.id;

type Line = { roleKey: string; targetId: number; sources: SourceEntry[] };
type Section = { title: string; titleLang?: string; level?: 2 | 3; lines: Line[] };
const sections: Section[] = [];
const facts: { label: string; value: string; lang?: string }[] = [];

// --- 種別ごとの事実と関係を収集 ---
if (entity.entity_type === 'song') {
  const sy = songYear(id);
  if (sy != null) facts.push({ label: bi('リリース年', 'Release year'), value: sy });
  sections.push({
    title: bi('アーティスト', 'Artists'),
    lines: songArtists(id).map((r) => ({ roleKey: r.role, targetId: r.entity_id, sources: sourcesFor('song_artists_sources', r.id) })),
  });
  sections.push({
    title: bi('楽曲クレジット', 'Song credits'),
    lines: songCredits(id).map((r) => ({ roleKey: r.role, targetId: r.entity_id, sources: sourcesFor('song_credits_sources', r.id) })),
  });
  sections.push({
    title: bi('収録された映像', 'Featured in'),
    lines: videosOfSong(id).map((r) => ({ roleKey: 'video', targetId: r.video_id, sources: [] })),
  });
} else if (entity.entity_type === 'video') {
  const m = getVideo(id);
  const vy = videoYear(id);
  if (vy != null) facts.push({ label: bi('制作年', 'Production year'), value: vy });
  if (m?.video_type) facts.push({ label: bi('種別', 'Type'), value: m.video_type });
  sections.push({
    title: bi('楽曲', 'Songs'),
    lines: videoSongs(id).map((r) => ({ roleKey: 'song', targetId: r.song_id, sources: [] })),
  });
  // クレジット欄：MVクレジット（監督・出演）に video_songs 経由の楽曲クレジット（作詞・作曲・編曲）を統合。
  // 単曲MVは1欄に統合、複数楽曲（メドレー）は楽曲ごとに小見出しで分ける。
  // ハブは credited_name_id・atDate を解決せず neutralName（primary逐語）で一律描画する。
  const songGroups = videoSongCreditGroups(id);
  const videoCreditLines: Line[] = videoCredits(id).map((r) => ({ roleKey: r.role, targetId: r.entity_id, sources: sourcesFor('video_credits_sources', r.id) }));
  const songCreditLine = (c: { id: number; role: string; entity_id: number }): Line =>
    ({ roleKey: c.role, targetId: c.entity_id, sources: sourcesFor('song_credits_sources', c.id) });
  if (songGroups.length <= 1) {
    sections.push({
      title: bi('クレジット', 'Credits'),
      lines: [...videoCreditLines, ...(songGroups[0]?.credits ?? []).map(songCreditLine)],
    });
  } else {
    sections.push({ title: bi('クレジット', 'Credits'), lines: videoCreditLines });
    for (const g of songGroups) {
      const st = neutralName(g.songId, 'song');
      sections.push({ title: st.text, titleLang: st.lang, level: 3, lines: g.credits.map(songCreditLine) });
    }
  }
} else {
  // person / group：関与の逆引き
  sections.push({
    title: bi('映像での関与', 'Music video work'),
    lines: videoCreditsOfEntity(id).map((r) => ({ roleKey: r.role, targetId: r.video_id, sources: sourcesFor('video_credits_sources', r.id) })),
  });
  sections.push({
    title: bi('楽曲クレジット', 'Song credits'),
    lines: songCreditsOfEntity(id).map((r) => ({ roleKey: r.role, targetId: r.song_id, sources: sourcesFor('song_credits_sources', r.id) })),
  });
  sections.push({
    title: bi('アーティストとして', 'As artist'),
    lines: songArtistOf(id).map((r) => ({ roleKey: r.role, targetId: r.song_id, sources: sourcesFor('song_artists_sources', r.id) })),
  });
}
const shown = sections.filter((s) => s.lines.length > 0);

const title = neutralName(id, entity.entity_type);
const pageTitle = `${title.text} — ${SITE_NAME}`;
const alternates = [
  { hreflang: 'x-default', path: neutralPath(id) },
  { hreflang: 'ja', path: langPath('ja', id) },
  { hreflang: 'en', path: langPath('en', id) },
];
---
<Base pageLang="mul" title={pageTitle} canonicalPath={neutralPath(id)} alternates={alternates}>
  <p class="kicker"><a href={neutralHome()}>{SITE_NAME}</a> · melothea{id}</p>
  <h1 lang={title.lang}>{title.text}</h1>

  <dl class="facts">
    <dt>ID</dt><dd>melothea{id}</dd>
    <dt>{bi('種別区分', 'Type')}</dt>
    <dd>{entity.entity_type}（{typeLabel.ja[entity.entity_type]} / {typeLabel.en[entity.entity_type]}）</dd>
    {facts.map((f) => (<><dt>{f.label}</dt><dd lang={f.lang}>{f.value}</dd></>))}
  </dl>

  {shown.map((sec) => (
    <section>
      <h2>{sec.title}</h2>
      <ul class="rel">
        {sec.lines.map((ln) => {
          const t = entityTypeOf(ln.targetId)!;
          const nm = neutralName(ln.targetId, t);
          return (
            <li>
              <span class="role">{ln.roleKey}</span>
              <a href={neutralPath(ln.targetId)} lang={nm.lang}>{nm.text}</a>
              <SourceList sources={ln.sources} summary={bi('出典', 'Sources')} verifiedLabel={bi('編纂者確認', 'Editor-verified')} />

            </li>
          );
        })}
      </ul>
    </section>
  ))}

  <nav class="lang">
    <span class="site">{bi('この項目を言語ページで', 'This entry in')}: </span>
    <a href={langPath('ja', id)} hreflang="ja" lang="ja">日本語</a>
    <a href={langPath('en', id)} hreflang="en" lang="en">English</a>
  </nav>

  <footer>
    {bi('構造化データ CC0 1.0 / 解説文 CC BY-SA 4.0', 'Structured data CC0 1.0 / prose CC BY-SA 4.0')} ·
    © {SITE_NAME} contributors
  </footer>
</Base>
