---
// 言語中立ハブ（実体URI＝/melothea{n}/）。言語を特権化せず、言語選択ページへ縮退する。
// hreflang の x-default 受け皿を兼ねる。事実・関係・出典は言語ページ側で描画する。
import Base from '../layouts/Base.astro';
import { allEntities, entityTypeOf, neutralName, renderDisplayName, songArtists, videoMainArtists } from '../lib/entities.ts';
import { neutralPath, langPath, neutralHome, typeLabel, neutralTypeLabelJa, SITE_NAME } from '../lib/i18n.ts';
import type { EntityRow } from '../lib/db.ts';

export function getStaticPaths() {
  // status で絞らず draft 行もページ生成する。
  return allEntities().map((e) => ({ params: { id: String(e.id) }, props: { entity: e } }));
}
const { entity } = Astro.props as { entity: EntityRow };
const id = entity.id;
const entityType = entity.entity_type;

// 冠に載せる main アーティストの entity_id 集合（楽曲・映像のみ。featured は含めない）。
const mainArtistIds: number[] =
  entityType === 'video'
    ? videoMainArtists(id).map((r) => r.entity_id)
    : entityType === 'song'
      ? songArtists(id).filter((r) => r.role === 'main').map((r) => r.entity_id)
      : [];

const crownParts = (lang: 'ja' | 'en') =>
  mainArtistIds.map((aid) => renderDisplayName(aid, entityTypeOf(aid)!, lang).main);

const jaResolved = renderDisplayName(id, entityType, 'ja');
const enResolved = renderDisplayName(id, entityType, 'en');
const jaCrownParts = crownParts('ja');
const enCrownParts = crownParts('en');

const neutralTitle = neutralName(id, entityType);
const enTypeLabel = typeLabel.en[entityType];
const omitEnTitlePart = enResolved.degraded || enResolved.main.text === neutralTitle.text;
const pageTitle = omitEnTitlePart
  ? `${neutralTitle.text} (${enTypeLabel}) - ${SITE_NAME}`
  : `${neutralTitle.text} - ${enResolved.main.text} (${enTypeLabel}) - ${SITE_NAME}`;

const alternates = [
  { hreflang: 'x-default', path: neutralPath(id) },
  { hreflang: 'ja', path: langPath('ja', id) },
  { hreflang: 'en', path: langPath('en', id) },
];
---
<Base pageLang="mul" title={pageTitle} canonicalPath={neutralPath(id)} alternates={alternates}>
  <h1><a href={neutralHome()}>Melothea</a></h1>
  <p class="kicker">melothea{id}</p>

  <ul class="langs">
    <li>{jaCrownParts.map((p, i) => (<>{i > 0 && '、'}<span lang={p.lang}>{p.text}</span></>))}{jaCrownParts.length > 0 && ' - '}<span lang={jaResolved.main.lang}>{jaResolved.main.text}</span>（{neutralTypeLabelJa[entityType]}） | <a href={langPath('ja', id)} hreflang="ja" lang="ja">日本語</a></li>
    <li>{enCrownParts.map((p, i) => (<>{i > 0 && ', '}<span lang={p.lang}>{p.text}</span></>))}{enCrownParts.length > 0 && ' - '}<span lang={enResolved.main.lang}>{enResolved.main.text}</span> ({typeLabel.en[entityType]}) | <a href={langPath('en', id)} hreflang="en" lang="en">English</a></li>
  </ul>

  <footer>
    <p lang="ja">構造化データ CC0 1.0 / 解説文 CC BY-SA 4.0</p>
    <p lang="en">Structured data CC0 1.0 / prose CC BY-SA 4.0 · © {SITE_NAME} contributors</p>
  </footer>
</Base>
